{
  "name": "java-brew-bites-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "build": "rimraf .node-localstorage && cross-env NODE_OPTIONS=--localstorage-file=.node-localstorage next build",
    "dev": "rimraf .next .node-localstorage && cross-env NODE_OPTIONS=--localstorage-file=.node-localstorage next dev",
    "start": "sh -c 'rm -rf .node-localstorage; NODE_OPTIONS=\"--localstorage-file=.node-localstorage\" next start'",
    "lint": "next lint"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "axios": "^1.15.0",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "lucide-react": "^0.511.0",
    "next": "15.3.0",
    "react": "19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.72.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.5",
    "postcss": "^8.5.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
