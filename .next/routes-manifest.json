{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/dashboard/orders/[id]",
      "regex": "^/dashboard/orders/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/dashboard/orders/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/dashboard/analytics",
      "regex": "^/dashboard/analytics(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/analytics(?:/)?$"
    },
    {
      "page": "/dashboard/management",
      "regex": "^/dashboard/management(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/management(?:/)?$"
    },
    {
      "page": "/dashboard/management/activity-logs",
      "regex": "^/dashboard/management/activity\\-logs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/management/activity\\-logs(?:/)?$"
    },
    {
      "page": "/dashboard/management/gallery",
      "regex": "^/dashboard/management/gallery(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/management/gallery(?:/)?$"
    },
    {
      "page": "/dashboard/management/menu",
      "regex": "^/dashboard/management/menu(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/management/menu(?:/)?$"
    },
    {
      "page": "/dashboard/management/users",
      "regex": "^/dashboard/management/users(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/management/users(?:/)?$"
    },
    {
      "page": "/dashboard/messages",
      "regex": "^/dashboard/messages(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/messages(?:/)?$"
    },
    {
      "page": "/dashboard/newsletter",
      "regex": "^/dashboard/newsletter(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/newsletter(?:/)?$"
    },
    {
      "page": "/dashboard/notifications",
      "regex": "^/dashboard/notifications(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/notifications(?:/)?$"
    },
    {
      "page": "/dashboard/orders",
      "regex": "^/dashboard/orders(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/orders(?:/)?$"
    },
    {
      "page": "/dashboard/reports",
      "regex": "^/dashboard/reports(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/reports(?:/)?$"
    },
    {
      "page": "/dashboard/settings",
      "regex": "^/dashboard/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/settings(?:/)?$"
    },
    {
      "page": "/forbidden",
      "regex": "^/forbidden(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/forbidden(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": []
}